# ============================================
# Ireland Explorer — .gitignore
# ============================================

# ── Environment & Secrets ──
.env
.env.*
*.env
*.env.*
!.env.example
*token.json*
*credentials.json*
*.pem

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/

# ── Node / NPM / Yarn ──
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
package-lock.json

# ── Expo / React Native ──
.expo/
*.jks
*.p8
*.p12
*.mobileprovision
expo-env.d.ts

# ── Next.js (Admin Dashboard) ──
.next/
out/
next-env.d.ts

# ── Build & Production ──
build/
dist/
*.tsbuildinfo
coverage/

# ── IDE & Editors ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── System Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# ── Docker Volumes & Data ──
docker-data/
postgres-data/
minio-data/

# ── Test Scripts (development only) ──
test_*.py
reset_points.py

# ── Demo / Development Files ──
phone_frame.html

# ── Archives & Large Assets ──
*.zip
*.tar.gz
*.tar
*.tgz
*.pack
*.deb
*.dylib

# ── Misc ──
.cache/
.vercel
chainlit.md
.chainlit/
.ipynb_checkpoints/
.ac
android-sdk/

# ── Gemini Antigravity (AI assistant) ──
.gemini/
