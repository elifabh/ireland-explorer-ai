{
  "expo": {
    "name": "Ireland Explorer",
    "slug": "ireland-explorer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ireland-explorer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find nearby Irish attractions and check-in",
        "NSCameraUsageDescription": "Take photos to complete stops and earn points",
        "NSPhotoLibraryUsageDescription": "Select photos for stop check-in"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#059669"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#059669"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Find nearby Irish attractions and check-in"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Select photos for stop check-in",
          "cameraPermission": "Take photos to complete stops and earn points"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
